# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://freeframe:freeframe@localhost:5432/freeframe
REDIS_URL=redis://localhost:6379/0

# S3 Storage — "minio" for local MinIO (dev), "s3" for AWS S3 (prod)
S3_STORAGE=minio
S3_BUCKET=freeframe
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
# S3_PUBLIC_ENDPOINT=http://localhost:9000  # Only needed for MinIO behind Docker

# To use AWS S3 instead, set:
# S3_STORAGE=s3
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY=YOUR_AWS_ACCESS_KEY_ID
# S3_SECRET_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# S3_REGION=ap-south-1

# JWT Auth
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend
FRONTEND_URL=http://localhost:3000

# Transcoder
TRANSCODER_ENGINE=ffmpeg

# Email — supports "ses" or "smtp"
MAIL_PROVIDER=ses
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=FreeFrame

# AWS SES credentials (when MAIL_PROVIDER=ses)
AWS_MAIL_ACCESS_KEY_ID=
AWS_MAIL_SECRET_ACCESS_KEY=
AWS_MAIL_REGION=us-east-1

# SMTP settings (when MAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# Worker concurrency settings (adjust based on server resources)
TRANSCODING_CONCURRENCY=2  # Number of concurrent video transcoding jobs (CPU intensive)
EMAIL_CONCURRENCY=2        # Number of concurrent email sending jobs
